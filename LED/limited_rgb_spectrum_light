int redPin = 9;
int greenPin = 6;
int bluePin = 3;
int voltPin1 = A4;
int voltPin2 = A9;

float redBrightness = 0;
float greenBrightness = 0;
float blueBrightness = 0;
int delayTime = 1050;


int calculateBrightness(int analogPin1, int analogPin2, int voltPin) {
  int tenBitNum;
  float brightness;
  if (voltPin==1) {
    tenBitNum = analogRead(analogPin1);
  } 
  else if (voltPin==2) {
    tenBitNum = analogRead(analogPin2);
  } 
  else {
    tenBitNum = (analogRead(analogPin1) + analogRead(analogPin2))/2;
    
  }
  brightness = (255.0/1023.0) * tenBitNum;

  return brightness;
}

void setup() {
  pinMode(redPin, OUTPUT);
  pinMode(greenPin, OUTPUT);
  pinMode(bluePin, OUTPUT);

  pinMode(voltPin1, INPUT);
  pinMode(voltPin2, INPUT);

  Serial.begin(9600);
}

void loop() {
  redBrightness = calculateBrightness(voltPin1, voltPin2, 1);
  greenBrightness = calculateBrightness(voltPin1, voltPin2, 2);
  blueBrightness = calculateBrightness(voltPin1, voltPin2, 3);
  analogWrite(redPin, redBrightness);
  analogWrite(greenPin, greenBrightness);
  analogWrite(bluePin, blueBrightness);

  Serial.print("Red is ");
  Serial.print(redBrightness);
  Serial.print(", Green is ");
  Serial.print(greenBrightness);
  Serial.print(", Blue is ");
  Serial.println(blueBrightness);
  delay(delayTime);
}
